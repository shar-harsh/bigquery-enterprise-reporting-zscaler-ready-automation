{
  "config": {
    "max_parallel": 8,
    "retry_count": 3,
    "download_timeout_minutes": 15,
    "cleanup_every_minutes": 180
  },
  "jobs": [
    {
      "sql": "daily_report.sql",
      "time": "08:30",
